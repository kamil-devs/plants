      "Skróć pędy do pierwszej pary żywych pąków.",
      "Nie usuwaj wszystkich starych pędów naraz."
    ]
  },
  {
    "name": "Winogrona",
    "type": "owocowa",
    "pruning": {
      "main": { "start": "02-01", "end": "03-10" }
    },
    "instructions": [
