<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ splash screen: matches Compose background so there's no flash -->
    <style name="Theme.PlantPruningApp" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/background_light</item>
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowSplashScreenBackground">@color/background_light</item>
    </style>
</resources>
